{
  "name": "diary-search",
  "version": "1.1.7",
  "description": "OpenClaw 日记与会话检索插件 - 为喜欢写日记的你，或需要查找历史对话的场景",
  "type": "module",
  "main": "index.js",
  "files": [
    "index.js",
    "search.js",
    "session.js",
    "cron.js",
    "tokenizer.js",
    "synonyms.json",
    "openclaw.plugin.json",
    "skill/",
    "README.md"
  ],
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "diary",
    "search",
    "full-text-search",
    "bm25",
    "chinese-tokenizer"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sebrinass/diary-search.git"
  },
  "bugs": {
    "url": "https://github.com/sebrinass/diary-search/issues"
  },
  "homepage": "https://github.com/sebrinass/diary-search#readme",
  "dependencies": {
    "minisearch": "^7.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.1",
      "minGatewayVersion": "2026.3.1"
    },
    "build": {
      "openclawVersion": "2026.3.1",
      "pluginSdkVersion": "2026.3.1"
    }
  }
}
